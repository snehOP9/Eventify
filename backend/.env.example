# =========================
# Eventify Backend Env Vars
# =========================
# Server

PORT=8080

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/event_platform
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Frontend + CORS
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
APP_OAUTH2_REDIRECT_URI=http://localhost:5173/auth/callback
APP_OAUTH2_BACKEND_CALLBACK_BASE_URL=http://localhost:8080
APP_OAUTH2_CODE_TTL_SECONDS=90

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APP_GOOGLE_OAUTH2_REDIRECT_URI=http://localhost:8080/login/oauth2/code/google

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
APP_GITHUB_OAUTH2_REDIRECT_URI=http://localhost:8080/login/oauth2/code/github

# Auth cookies / JWT
APP_AUTH_COOKIES_SECURE=false
APP_AUTH_COOKIES_SAME_SITE=None
APP_JWT_SECRET=ZXZlbnQtcGxhdGZvcm0tand0LXNlY3JldC1rZXktY2hhbmdlLW1lLTIwMjY=

# Razorpay (test keys for development)
APP_RAZORPAY_KEY_ID=
APP_RAZORPAY_KEY_SECRET=
# Optional aliases used by some hosts/platform templates
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# SMTP for OTP/reset-password + registration emails
APP_MAIL_ENABLED=false
APP_MAIL_PROVIDER=smtp
APP_MAIL_FROM=no-reply@eventify.local
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# Resend HTTP API (recommended for hosted environments when SMTP ports are blocked)
APP_MAIL_RESEND_API_KEY=
APP_MAIL_RESEND_ENDPOINT=https://api.resend.com/emails
# Optional temporary override for Resend testing mode.
# When set, all outbound emails are redirected to this inbox.
APP_MAIL_RESEND_TESTING_RECIPIENT=
